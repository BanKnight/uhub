{
  "name": "uhub",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "echo \"Use bun run dev:admin | bun run dev:portal | bun run dev:api\"",
    "dev:admin": "bun --cwd apps/admin-web dev",
    "dev:portal": "bun --cwd apps/key-portal dev",
    "dev:api": "bun --cwd apps/api-worker dev",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun --cwd packages/shared build && bun --cwd packages/config build && bun --cwd packages/db build && bun --cwd packages/ui build",
    "build:apps": "bun --cwd apps/admin-web build && bun --cwd apps/key-portal build && bun --cwd apps/api-worker build",
    "typecheck": "bun run typecheck:packages && bun run typecheck:apps",
    "typecheck:packages": "bun --cwd packages/shared typecheck && bun --cwd packages/config typecheck && bun --cwd packages/db typecheck && bun --cwd packages/ui typecheck",
    "typecheck:apps": "bun --cwd apps/admin-web typecheck && bun --cwd apps/key-portal typecheck && bun --cwd apps/api-worker typecheck",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --organize-imports-enabled=false --assists-enabled=false --files-ignore-unknown=true .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run build",
    "prepare": "husky",
    "db:generate": "bun --cwd apps/api-worker drizzle-kit generate",
    "db:migrate:local": "bun x wrangler d1 migrations apply DB --local --cwd apps/api-worker",
    "test:integration": "bun run test:integration:ci",
    "test:integration:smoke": "bun run test:integration:smoke:local",
    "test:integration:smoke:raw": "bun run test:integration:openai:nonstream && bun run test:integration:anthropic:invalid-request && bun run test:integration:gemini:nonstream && bun run test:integration:admin:channel-structured",
    "test:integration:smoke:local": "bun tests/run-with-local-worker.ts bun run test:integration:smoke:raw",
    "test:integration:ci": "bun run test:integration:ci:local",
    "test:integration:ci:raw": "bun run test:integration:openai && bun run test:integration:anthropic && bun run test:integration:gemini",
    "test:integration:openai": "bun run test:integration:openai:nonstream && bun run test:integration:portal:overview-quota && bun run test:integration:admin:channel-structured",
    "test:integration:openai:nonstream": "bun tests/integration/openai-nonstream.ts",
    "test:integration:openai:nonstream:local": "bun tests/run-with-local-worker.ts bun tests/integration/openai-nonstream.ts",
    "test:integration:anthropic": "bun run test:integration:anthropic:nonstream && bun run test:integration:anthropic:stream-text && bun run test:integration:anthropic:tool-use-stream && bun run test:integration:anthropic:tool-choice-auto-any && bun run test:integration:anthropic:tool-use-multi-nonstream && bun run test:integration:anthropic:tool-use-multi-stream && bun run test:integration:anthropic:tool-use-nonstream && bun run test:integration:anthropic:invalid-request && bun run test:integration:anthropic:load-balance && bun run test:integration:anthropic:gateway-failover && bun run test:integration:anthropic:tools-request",
    "test:integration:anthropic:nonstream": "bun tests/integration/anthropic-nonstream.ts",
    "test:integration:anthropic:nonstream:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-nonstream.ts",
    "test:integration:anthropic:stream-text": "bun tests/integration/anthropic-stream-text.ts",
    "test:integration:anthropic:stream-text:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-stream-text.ts",
    "test:integration:anthropic:tool-use-stream": "bun tests/integration/anthropic-tool-use-stream.ts",
    "test:integration:anthropic:tool-use-stream:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-tool-use-stream.ts",
    "test:integration:anthropic:tool-choice-auto-any": "bun tests/integration/anthropic-tool-choice-auto-any.ts",
    "test:integration:anthropic:tool-choice-auto-any:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-tool-choice-auto-any.ts",
    "test:integration:anthropic:tool-use-multi-nonstream": "bun tests/integration/anthropic-tool-use-multi-nonstream.ts",
    "test:integration:anthropic:tool-use-multi-nonstream:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-tool-use-multi-nonstream.ts",
    "test:integration:anthropic:tool-use-multi-stream": "bun tests/integration/anthropic-tool-use-multi-stream.ts",
    "test:integration:anthropic:tool-use-multi-stream:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-tool-use-multi-stream.ts",
    "test:integration:anthropic:tool-use-nonstream": "bun tests/integration/anthropic-tool-use-nonstream.ts",
    "test:integration:anthropic:tool-use-nonstream:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-tool-use-nonstream.ts",
    "test:integration:anthropic:invalid-request": "bun tests/integration/anthropic-invalid-request.ts",
    "test:integration:anthropic:invalid-request:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-invalid-request.ts",
    "test:integration:anthropic:load-balance": "bun tests/integration/anthropic-load-balance.ts",
    "test:integration:anthropic:load-balance:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-load-balance.ts",
    "test:integration:anthropic:gateway-failover": "bun tests/integration/anthropic-gateway-failover.ts",
    "test:integration:anthropic:gateway-failover:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-gateway-failover.ts",
    "test:integration:anthropic:tools-request": "bun tests/integration/anthropic-tools-request.ts",
    "test:integration:anthropic:tools-request:local": "bun tests/run-with-local-worker.ts bun tests/integration/anthropic-tools-request.ts",
    "test:integration:gemini": "bun run test:integration:gemini:nonstream && bun run test:integration:gemini:stream",
    "test:integration:gemini:nonstream": "bun tests/integration/gemini-nonstream.ts",
    "test:integration:gemini:nonstream:local": "bun tests/run-with-local-worker.ts bun tests/integration/gemini-nonstream.ts",
    "test:integration:gemini:stream": "bun tests/integration/gemini-stream.ts",
    "test:integration:gemini:stream:local": "bun tests/run-with-local-worker.ts bun tests/integration/gemini-stream.ts",
    "test:integration:admin:channel-structured": "bun tests/integration/admin-channel-structured.ts",
    "test:integration:admin:channel-structured:local": "bun tests/run-with-local-worker.ts bun tests/integration/admin-channel-structured.ts",
    "test:integration:admin:channel-structured:invalid": "bun tests/integration/admin-channel-structured-invalid.ts",
    "test:integration:admin:channel-structured:invalid:local": "bun tests/run-with-local-worker.ts bun tests/integration/admin-channel-structured-invalid.ts",
    "test:integration:portal:overview-quota": "bun tests/integration/portal-overview-quota.ts",
    "test:integration:portal:overview-quota:local": "bun tests/run-with-local-worker.ts bun tests/integration/portal-overview-quota.ts",
    "test:integration:ci:local": "bun tests/run-with-local-worker.ts bun run test:integration:ci:raw",
    "test:integration:openai:local": "bun tests/run-with-local-worker.ts bun run test:integration:openai",
    "test:integration:anthropic:local": "bun tests/run-with-local-worker.ts bun run test:integration:anthropic",
    "test:integration:gemini:local": "bun tests/run-with-local-worker.ts bun run test:integration:gemini",
    "test:e2e:core": "bun run test:e2e:core:local",
    "test:e2e:core:raw": "bun tests/e2e/core-flow.ts",
    "test:e2e:core:local": "bun tests/run-with-local-worker.ts bun run test:e2e:core:raw"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "typescript": "^5.8.3"
  }
}
